{
  "name": "app-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @app/web dev",
    "build": "pnpm --filter @app/web build",
    "start": "pnpm --filter @app/web start",
    "lint": "pnpm --filter @app/web lint",
    "db:push": "pnpm --filter @app/api db:push",
    "db:generate": "pnpm --filter @app/api db:generate",
    "db:migrate": "pnpm --filter @app/api db:migrate",
    "db:studio": "pnpm --filter @app/api db:studio"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.13",
      "@types/react-dom": "19.2.3"
    }
  }
}
