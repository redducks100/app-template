{
  "name": "app-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:app": "turbo run dev --filter=@app/app",
    "dev:api": "turbo run dev --filter=@app/api",
    "build": "turbo run build",
    "deploy": "turbo run deploy:cf",
    "deploy:api": "turbo run deploy:cf --filter=@app/api",
    "deploy:app": "turbo run deploy:cf --filter=@app/app",
    "db:push": "turbo run db:push --filter=@app/api",
    "db:generate": "turbo run db:generate --filter=@app/api",
    "db:migrate": "turbo run db:migrate --filter=@app/api",
    "db:studio": "turbo run db:studio --filter=@app/api"
  },
  "devDependencies": {
    "turbo": "^2.8.13",
    "typescript": "catalog:"
  }
}
