{
  "name": "app-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "dev": "turbo run dev",
    "dev:app": "turbo run dev --filter=@app/app",
    "dev:api": "turbo run dev --filter=@app/api",
    "build": "turbo run build",
    "deploy:cf": "turbo run deploy:cf",
    "db:migrate": "turbo run db:migrate --filter=@app/api",
    "db:migrate:up": "turbo run db:migrate:up --filter=@app/api",
    "db:migrate:down": "turbo run db:migrate:down --filter=@app/api",
    "db:migrate:make": "turbo run db:migrate:make --filter=@app/api",
    "db:migrate:list": "turbo run db:migrate:list --filter=@app/api"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "oxlint": "^1.51.0",
    "turbo": "^2.8.13",
    "typescript": "catalog:"
  }
}
