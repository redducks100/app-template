    "@react-email/components": "^0.5.7",
    "better-auth": "catalog:",
    "kysely": "catalog:",
    "kysely-neon": "^2.0.2",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "resend": "^6.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "dotenv": "^16.5.0",
    "kysely-ctl": "^0.20.0",
    "typescript": "catalog:"
  }
