{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "globalEnv": ["DATABASE_URL", "CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_API_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deploy:cf": {
      "dependsOn": ["build"],
      "cache": false
    },
    "db:migrate": { "cache": false },
    "db:migrate:up": { "cache": false },
    "db:migrate:down": { "cache": false },
    "db:migrate:make": { "cache": false },
    "db:migrate:list": { "cache": false }
  }
}
